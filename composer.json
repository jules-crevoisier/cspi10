{
    "name": "cspi10/website",
    "description": "Site web CSPI10 — Chambre Syndicale des Propriétaires Immobiliers de l'Aube",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "vlucas/phpdotenv": "^5.6",
        "ezyang/htmlpurifier": "^4.19",
        "darkterminal/turso-client-http": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "App\\Core\\": "app/Core/"
        },
        "classmap": [
            "app/controller/",
            "app/models/",
            "app/config/"
        ],
        "files": [
            "app/config/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
