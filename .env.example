# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://votre-domaine.fr
# Minimum 32 caractères aléatoires — jamais commiter la vraie valeur
APP_SECRET=

# Base de données SQLite (volume Docker)
DATABASE_PATH=database/data/cspi.db

# Emails — Resend (https://resend.com/api-keys)
# Ne jamais mettre la clé dans le code source : Dockploy / .env local uniquement
RESEND_API_KEY=
CONTACT_FROM_EMAIL=no-reply@votre-domaine.fr
CONTACT_TO_EMAIL=contact@votre-domaine.fr
CONTACT_FROM_NAME="Site CSPI10"

# Espace adhérent (mot de passe partagé)
ESPACE_ADHERENT_PASSWORD=

# SEO / URLs canoniques
SITE_URL=https://votre-domaine.fr
