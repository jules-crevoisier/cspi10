# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_SECRET=changez-moi-en-production-minimum-32-caracteres

# Base de données — choisir UNE des deux options :

# Option A : SQLite locale (développement / volume Docker)
DATABASE_PATH=database/data/cspi.db

# Option B : Turso (production recommandée)
# TURSO_DATABASE_URL=libsql://votre-db-nom-votre-org.turso.io
# TURSO_AUTH_TOKEN=votre_token_turso

# Emails (Resend)
RESEND_API_KEY=
CONTACT_FROM_EMAIL=no-reply@votre-domaine.fr
CONTACT_TO_EMAIL=contact@votre-domaine.fr
CONTACT_FROM_NAME="Site CSPI10"

# Espace adhérent (mot de passe partagé)
ESPACE_ADHERENT_PASSWORD=

# SEO
SITE_URL=https://votre-domaine.fr
